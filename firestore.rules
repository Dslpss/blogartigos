rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar se o usuário é o administrador autorizado
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'dennisemannuel93@gmail.com';
    }

    // Regras para as configurações do blog
    match /settings/{setting} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Regras para os artigos e notícias
    match /articles/{article} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bloqueio padrão para qualquer outra coleção não especificada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
