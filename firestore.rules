rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Super Admin global helper
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'dennisemannuel93@gmail.com';
    }

    // Role-based helper: checks the user_roles collection
    function hasRole(role) {
      return request.auth != null && (
        isSuperAdmin() || 
        get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == role
      );
    }

    // Helper for any authorized staff (Admin or Editor)
    function isStaff() {
      return request.auth != null && (
        isSuperAdmin() || 
        exists(/databases/$(database)/documents/user_roles/$(request.auth.uid))
      );
    }

    // New helper to check for email-based invitations
    function hasInvite() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/user_roles/$( "invite_" + request.auth.token.email ));
    }

    // User Roles management
    match /user_roles/{userId} {
      // Allow reading own UID doc, own invite doc, or if admin
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        userId == ("invite_" + request.auth.token.email) ||
        hasRole('admin')
      );
      
      // Activation: User can create their own UID doc if they have an invite
      allow create: if request.auth != null && request.auth.uid == userId && hasInvite();
      
      // Deletion of old invite: User can delete the invite doc that matched their email
      allow delete: if request.auth != null && userId == ("invite_" + request.auth.token.email);

      // Management: Only Super Admin or existing Admins can manage others
      allow write: if isSuperAdmin() || hasRole('admin');
    }

    // Blog settings: Only Admins can change
    match /settings/{setting} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // Articles & News: Admins and Editors can write
    match /articles/{article} {
      allow read: if true;
      // Allow public to update ONLY the views field (for page counters) and only by +1
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && request.resource.data.views == resource.data.views + 1;
      allow write: if isStaff();
    }

    // Stats: global and per-article (admin-only reads)
    match /stats/{stat} {
      allow read: if hasRole('admin');
      // Allow public to update ONLY the totalViews field and only by +1
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalViews']) && request.resource.data.totalViews == resource.data.totalViews + 1;
      // Allow creating the stats doc only when initializing totalViews == 1
      allow create: if request.resource.data.keys().hasOnly(['totalViews']) && request.resource.data.totalViews == 1;
      allow write: if hasRole('admin');
    }

    match /article_stats/{articleId} {
      allow read: if hasRole('admin');
      // Allow public to increment views by exactly +1
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && request.resource.data.views == resource.data.views + 1;
      allow create: if request.resource.data.keys().hasOnly(['views']) && request.resource.data.views == 1;
      allow write: if hasRole('admin');
    }

    match /polls/{pollId} {
      allow read: if true;
      // Allow public to update ONLY the submissionsCount for the counter
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['submissionsCount']) || hasRole('admin');
      allow create, delete: if hasRole('admin');
    }

    match /poll_submissions/{submission} {
      allow create: if true;
      allow read, update, delete: if hasRole('admin');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
